{
  "name": "zentao-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "禅道 RESTful API v2.0 TypeScript SDK monorepo",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @zentao/sdk dev",
    "docs": "pnpm --filter @zentao/docs start",
    "docs:build": "pnpm --filter @zentao/docs build",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.3"
}
